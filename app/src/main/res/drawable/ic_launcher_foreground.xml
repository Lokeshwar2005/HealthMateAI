<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Brain outline left hemisphere -->
    <path
        android:pathData="M48,36 C42,36 37,38 35,42 C33,46 33,50 35,54 C36,56 37,58 38,59 C39,61 40,63 40,66 L40,68"
        android:strokeWidth="2.2"
        android:strokeColor="#00E5FF"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Brain outline right hemisphere -->
    <path
        android:pathData="M60,36 C66,36 71,38 73,42 C75,46 75,50 73,54 C72,56 71,58 70,59 C69,61 68,63 68,66 L68,68"
        android:strokeWidth="2.2"
        android:strokeColor="#00E5FF"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Brain top connection -->
    <path
        android:pathData="M48,36 C50,32 58,32 60,36"
        android:strokeWidth="2.2"
        android:strokeColor="#00E5FF"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Brain center division -->
    <path
        android:pathData="M54,34 L54,68"
        android:strokeWidth="1.5"
        android:strokeColor="#00BCD4"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Brain internal neural lines left -->
    <path
        android:pathData="M42,42 C46,44 48,48 46,52"
        android:strokeWidth="1.2"
        android:strokeColor="#26C6DA"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Brain internal neural lines right -->
    <path
        android:pathData="M66,42 C62,44 60,48 62,52"
        android:strokeWidth="1.2"
        android:strokeColor="#26C6DA"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Neural nodes -->
    <path
        android:fillColor="#00E5FF"
        android:pathData="M46,52 m-1.5,0 a1.5,1.5 0,1 1,3 0 a1.5,1.5 0,1 1,-3 0" />
    <path
        android:fillColor="#00E5FF"
        android:pathData="M62,52 m-1.5,0 a1.5,1.5 0,1 1,3 0 a1.5,1.5 0,1 1,-3 0" />
    <path
        android:fillColor="#00E5FF"
        android:pathData="M54,46 m-1.8,0 a1.8,1.8 0,1 1,3.6 0 a1.8,1.8 0,1 1,-3.6 0" />

    <!-- ECG / Heartbeat line across bottom -->
    <path
        android:pathData="M26,72 L38,72 L42,72 L45,66 L48,78 L51,62 L54,76 L57,72 L60,72 L82,72"
        android:strokeWidth="2.4"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="26"
                android:startY="72"
                android:endX="82"
                android:endY="72">
                <item android:color="#4400E5FF" android:offset="0.0" />
                <item android:color="#FF00E5FF" android:offset="0.3" />
                <item android:color="#FF00BCD4" android:offset="0.7" />
                <item android:color="#4400E5FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stem / base of brain -->
    <path
        android:pathData="M40,68 L68,68"
        android:strokeWidth="2"
        android:strokeColor="#00BCD4"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />
</vector>